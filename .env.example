# ============================================================
# NutriClinic SaaS - Environment Variables Template
# نسخة cPanel + MySQL
# انسخ هذا الملف إلى .env للتشغيل على cPanel
# ============================================================

# ===== قاعدة البيانات MySQL على cPanel =====
# أنشئ قاعدة البيانات من cPanel → MySQL Databases
# cPanel يضيف بادئة اسم المستخدم تلقائيًا (مثلاً: matrmylq_)
#
# الصيغة: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# - HOST: غالبًا "localhost" على الاستضافة المشتركة
# - PORT: 3306 افتراضيًا
# - PASSWORD: يجب أن تكون URL-encoded إذا تحتوي رموز خاصة
#   (مثلاً: "!" يصبح "%21"، "@" يصبح "%40"، "#" يصبح "%23")
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/DATABASE"

# ===== المصادقة JWT =====
# ولّد سلسلة عشوائية بطول 64 خانة:
#   openssl rand -base64 64
JWT_SECRET="CHANGE_ME_TO_RANDOM_64_CHAR_STRING"

# ===== NextAuth (احتياطي - غير مستخدم فعليًا لكن مطلوب لبعض المكتبات) =====
# ولّد سلسلة عشوائية بطول 32 خانة:
#   openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_TO_RANDOM_32_CHAR_STRING"
NEXTAUTH_URL="https://your-domain.com"

# ===== بيئة التشغيل =====
NODE_ENV="production"
PORT=3000
HOSTNAME=0.0.0.0

# ===== مفتاح الإعداد (لـ /api/setup) =====
# استخدم هذا المفتاح لإعداد قاعدة البيانات أول مرة عبر POST /api/setup
SETUP_KEY="nutriclinic-setup-2024"

# ===== مفتاح cron jobs =====
# يُستخدم لحماية endpoints المجدولة (مثل /api/cron/disable-expired?key=...)
# يمكن استخدام نفس قيمة SETUP_KEY أو قيمة مختلفة
CRON_KEY="nutriclinic-cron-2024"

# ===== إعدادات التطبيق =====
FREE_TRIAL_DAYS=14
FREE_TRIAL_ENABLED=true

# ===== مفاتيح الذكاء الاصطناعي (اختياري - يمكن إضافتها من لوحة الإدارة) =====
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
