# ============================================================
# NutriClinic SaaS - Environment Variables Template
# نسخة Vercel + Neon (PostgreSQL)
# انسخ هذا الملف إلى .env.local للتطوير المحلي
# ============================================================

# ===== قاعدة البيانات Neon PostgreSQL =====
# احصل عليه من: https://console.neon.tech (Connection Details)
# مثال: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# (اختياري) رابط الاتصال المباشر بدون pooler — لاستخدامه مع migrations
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ===== المصادقة JWT =====
# ولّد سلسلة عشوائية: openssl rand -base64 64
JWT_SECRET="CHANGE_ME_TO_RANDOM_64_CHAR_STRING"

# ===== NextAuth =====
# ولّد سلسلة عشوائية: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_TO_RANDOM_32_CHAR_STRING"
NEXTAUTH_URL="https://your-app.vercel.app"

# ===== بيئة التشغيل =====
NODE_ENV="production"

# ===== إعدادات التطبيق =====
# FREE_TRIAL_DAYS=14
# FREE_TRIAL_ENABLED=true
