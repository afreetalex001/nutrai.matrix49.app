# ============================================================
# NutriClinic SaaS - Apache Rewrite Rules for cPanel Passenger
# يعمل مع CloudLinux/Phusion Passenger بدون حاجة لـ proxy يدوي
# ============================================================
# ملاحظة: cPanel يضيف تلقائياً إعدادات Passenger في أعلى الملف.
# لا تُزِل تلك الإعدادات. هذا الملف يضيف قاعدة إعادة كتابة للملفات
# الثابتة فقط.
# ============================================================

<IfModule mod_rewrite.c>
    RewriteEngine On

    # تقديم ملفات Next.js الثابتة مباشرة من .next/static
    # (Passenger لا يري هذه الملفات تلقائياً، لأنها خارج public/)
    RewriteCond %{REQUEST_URI} ^/_next/static/(.*)$
    RewriteCond %{DOCUMENT_ROOT}/.next/static/%1 -f
    RewriteRule ^_next/static/(.*)$ .next/static/$1 [L]

    # السماح بالوصول المباشر للملفات الموجودة في public/
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
</IfModule>

# تمرير headers مهمة إلى تطبيق Node.js
<IfModule mod_headers.c>
    RequestHeader set X-Forwarded-Proto "https"
</IfModule>

# مهلة طويلة لطلبات AI التي قد تستغرق وقتًا أطول
<IfModule mod_proxy.c>
    ProxyTimeout 300
</IfModule>
